{
  "name": "fsim",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n backend,sim,editor -c cyan,green,magenta \"npm run dev:backend\" \"npm run sim:vite\" \"npm run editor:vite\"",
    "debug": "npm run editor:dev",
    "dev:backend": "node tools/dev-server.mjs",
    "editor:backend": "npm run dev:backend",
    "editor:build": "vite build --config vite.editor.config.mjs",
    "editor:dev": "concurrently -k -n editor-api,editor-ui -c cyan,magenta \"npm run editor:backend\" \"npm run editor:vite\"",
    "editor:vite": "vite --config vite.editor.config.mjs",
    "sim:dev": "concurrently -k -n sim-api,sim-ui -c cyan,green \"npm run dev:backend\" \"npm run sim:vite\"",
    "sim:build": "vite build --config vite.sim.config.mjs",
    "sim:vite": "vite --config vite.sim.config.mjs",
    "build": "npm run sim:build && npm run editor:build",
    "typecheck": "tsc --project tsconfig.json",
    "start": "node server.js",
    "serve": "node server.js",
    "build:world": "node --import tsx/esm tools/bake-map.mjs && node --import tsx/esm tools/build-world.mjs",
    "server": "node server.js",
    "smoke": "node scripts/smoke.mjs",
    "screenshot": "node scripts/screenshot.mjs",
    "screenshot:batch": "node scripts/screenshot-batcher.mjs",
    "screenshot:shader-pipeline": "node scripts/screenshot-batcher.mjs --config=config/shader_pipeline_vantage_points.json --filter=shader_",
    "screenshot:cleanup": "node scripts/screenshot-cleanup.mjs",
    "test:unit": "tsx --test tests/*.test.mjs",
    "test:e2e": "playwright test",
    "test:e2e:perf": "playwright test tests/e2e/perf/fsim.perf.spec.ts",
    "test:e2e:perf:terrain": "playwright test tests/e2e/perf/terrain.perf.spec.ts",
    "test:e2e:headed": "playwright test --headed",
    "test:perf": "node scripts/perf.mjs",
    "perf:capture": "node scripts/capture-perf-report.mjs",
    "perf:analyze": "node scripts/analyze-perf-report.mjs",
    "perf:terrain:suite": "node scripts/terrain-perf-suite.mjs",
    "perf:terrain:ab": "node scripts/terrain-perf-ab.mjs",
    "world:assets:seed": "node tools/seed-world-asset-sources.mjs",
    "world:assets:process": "node tools/process-world-asset.mjs --all",
    "world:assets:check": "node tools/check-world-asset-budgets.mjs",
    "test": "npm run test:unit && npm run smoke"
  },
  "dependencies": {
    "@dimforge/rapier3d-compat": "^0.19.3",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lil-gui": "^0.21.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.3.1",
    "three": "0.160.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.4",
    "@types/node": "^25.5.0",
    "@vitejs/plugin-react": "^5.0.4",
    "concurrently": "^9.2.1",
    "playwright": "^1.58.2",
    "tailwindcss": "^4.1.4",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^7.1.9"
  },
  "packageManager": "npm@11.12.1"
}
